# ── Product app (master sign-up / sign-in lives here, NOT in this project) ──
# Where the marketing site's "Get started" / "Sign in" buttons deep-link to.
# The app owns auth on app.liveconnectusa.com (shared .liveconnectusa.com SSO cookie).
NEXT_PUBLIC_APP_URL=https://app.liveconnectusa.com

# ── Contact form email (Resend) ──
# Create a key at https://resend.com and verify the sending domain.
RESEND_API_KEY=
# Must be an address on a Resend-verified domain:
CONTACT_FROM=LiveConnect <noreply@liveconnectusa.com>
# Comma-separated recipients (defaults to these two if unset):
CONTACT_TO=graham@madebysprint.com,isabel.cable@accessfortworth.com

# ── Contact form storage (Supabase) ──
# Submissions are also saved to the contact_submissions table (see supabase/schema.sql).
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key (server-only — never expose to the browser):
SUPABASE_SERVICE_ROLE_KEY=
